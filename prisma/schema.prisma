generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id         String   @id @default(uuid())
  externalId String?  @unique
  firstName  String
  lastName   String
  email      String   @unique
  phone      String?
  picture    String?
  summary    String?
  nextAction String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("leads")
}
