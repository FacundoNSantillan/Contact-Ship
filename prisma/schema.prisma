generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(uuid())
  externalId  String?  @unique          
  firstName   String
  lastName    String
  email       String   @unique          
  phone       String?
  picture     String?
  summary     String?  @db.Text          
  nextAction  String?  @db.Text         
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("leads")
}