# --- APP CONFIG ---
PORT=3000

# --- DATABASE (Supabase / PostgreSQL) ---
# Si usas Supabase, la URL se ve así (Transaction mode es recomendado para Prisma):
# postgresql://postgres.[ID_PROYECTO]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# --- REDIS CONFIG ---
# Formato: redis://[USER]:[PASSWORD]@[HOST]:[PORT]
REDIS_URL="redis://localhost:6379"

# --- GOOGLE AI (Gemini) ---
# Consigue tu clave en: https://aistudio.google.com/
GEMINI_API_KEY=tu_api_key_aqui